# === Obsidian Vault 宿主机路径（挂载到容器内 /obsidian）===
OBSIDIAN_VAULT_PATH=/Users/jihao/Documents/Obsidian

# === 数据库 ===
MYSQL_ROOT_PASSWORD=aiwiki123

# === Redis（可选，不设置则无密码）===
REDIS_PASSWORD=

# === 前端 API 地址（浏览器访问后端的地址）===
# 本地开发默认 http://localhost:8080
# 部署到服务器时改为服务器公网 IP 或域名
VITE_API_BASE_URL=http://localhost:8080

# === AI 模型密钥（至少配置其中一个）===
# 阿里云 DashScope（通义千问）
DASHSCOPE_API_KEY=

# OpenAI 兼容接口
OPENAI_BASE_URL=
OPENAI_API_KEY=
