# ---- MySQL（复用宿主机已有实例）----
MYSQL_PORT=3306
MYSQL_USERNAME=ai_admin
MYSQL_PASSWORD=ai_admin_123456

# ---- Redis（复用宿主机已有实例，database 1 避免与其他项目冲突）----
REDIS_PORT=6379
REDIS_PASSWORD=redis_123456
REDIS_DATABASE=1

# ---- LLM（在页面设置中配置，此处填占位符防止启动报错）----
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_API_KEY=placeholder
DASHSCOPE_API_KEY=placeholder

# ---- Obsidian Vault 挂载路径 ----
OBSIDIAN_VAULT_PATH=/home/coder/data

# ---- 前端配置 ----
# 浏览器访问后端的地址（带项目路径前缀）
VITE_API_BASE_URL=http://39.97.248.52/llm-wiki-rag
# 前端静态资源路径前缀（需与 Nginx location 保持一致）
VITE_BASE_PATH=/llm-wiki-rag/
