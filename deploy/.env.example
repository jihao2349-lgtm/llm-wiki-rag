# ============================================================
# AI Wiki - 生产环境配置模板
# 使用方式：cp .env.example .env，然后填写真实值
# ============================================================

# ---- MySQL ----
MYSQL_ROOT_PASSWORD=请修改为强密码

# ---- Redis（可选，留空则不设密码）----
REDIS_PASSWORD=

# ---- LLM 配置（二选一）----
# DeepSeek
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 阿里云百炼（如果使用 DashScope）
DASHSCOPE_API_KEY=

# ---- Obsidian Vault 挂载路径（服务器上的绝对路径）----
OBSIDIAN_VAULT_PATH=/data/obsidian

# ---- 前端 API 地址（浏览器能访问到的后端地址，即 Nginx 公网地址）----
# 格式：http://公网IP 或 https://你的域名
VITE_API_BASE_URL=http://39.97.248.52
