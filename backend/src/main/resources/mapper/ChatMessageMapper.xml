<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.jihao.aiwiki.mapper.ChatMessageMapper">

    <resultMap id="messageRM" type="com.jihao.aiwiki.entity.ChatMessageDO">
        <id column="id" property="id"/>
        <result column="session_id" property="sessionId"/>
        <result column="role" property="role"/>
        <result column="content" property="content"/>
        <result column="citations" property="citations"/>
        <result column="saved_path" property="savedPath"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO chat_message (session_id, role, content, citations, saved_path)
        VALUES (#{sessionId}, #{role}, #{content}, #{citations}, #{savedPath})
    </insert>

    <select id="selectById" resultMap="messageRM">
        SELECT * FROM chat_message WHERE id = #{id}
    </select>

    <select id="selectBySessionId" resultMap="messageRM">
        SELECT * FROM chat_message
        WHERE session_id = #{sessionId}
        ORDER BY create_time ASC
    </select>

    <update id="updateSavedPath">
        UPDATE chat_message SET saved_path = #{savedPath} WHERE id = #{id}
    </update>

</mapper>
