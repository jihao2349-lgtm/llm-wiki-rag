<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.jihao.aiwiki.mapper.ChatSessionMapper">

    <resultMap id="sessionRM" type="com.jihao.aiwiki.entity.ChatSessionDO">
        <id column="id" property="id"/>
        <result column="vault_id" property="vaultId"/>
        <result column="title" property="title"/>
        <result column="deleted" property="deleted"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO chat_session (vault_id, title, deleted)
        VALUES (#{vaultId}, #{title}, 0)
    </insert>

    <select id="selectById" resultMap="sessionRM">
        SELECT * FROM chat_session WHERE id = #{id} AND deleted = 0
    </select>

    <select id="selectByVaultId" resultMap="sessionRM">
        SELECT * FROM chat_session
        WHERE vault_id = #{vaultId} AND deleted = 0
        ORDER BY create_time DESC
    </select>

</mapper>
